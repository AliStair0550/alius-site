// ============================================================
// Alius database schema
// Used by tankeprofil and future tools
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PROFILE
// A single person's tankeprofil result.
// Can be anonymous initially, claimed via email later.
// Same person can be in multiple teams without retaking the test.
// ============================================================

model Profile {
  id          String   @id @default(cuid())

  // Identity (optional at first, can be added later)
  email       String?  @unique
  displayName String?

  // Result
  totals      Json     // { A: 8, B: 12, C: 3, D: 1 }
  primary     String   // "A" | "B" | "C" | "D"
  secondary   String
  weakest     String

  // Raw selections, so we can recalculate if the formula changes
  selections  Json     // Selections array from the test

  // Returnable link without login
  accessToken String   @unique @default(cuid())

  // Tracking
  source      String?  // "individual" | "team_invitation" | "workshop"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  teamMemberships TeamMember[]

  @@index([email])
  @@index([accessToken])
}

// ============================================================
// TEAM SESSION
// A group of people taking the test together.
// Three tokens give role-based access without user accounts.
// ============================================================

model TeamSession {
  id           String   @id @default(cuid())

  // Identification
  name         String
  companyName  String?
  ownerEmail   String
  ownerName    String?

  // Status
  status       TeamSessionStatus @default(OPEN)

  // Access via long random tokens in URL
  // join = invitees can submit but not see report or admin
  // report = anyone can view report but not modify
  // admin = owner can manage session
  joinToken    String   @unique @default(cuid())
  reportToken  String   @unique @default(cuid())
  adminToken   String   @unique @default(cuid())

  // Expected number of participants (from request)
  expectedSize Int?

  // Tracking
  createdAt    DateTime  @default(now())
  closedAt     DateTime?

  // Relations
  members      TeamMember[]
  request      TeamRequest?

  @@index([joinToken])
  @@index([reportToken])
  @@index([adminToken])
  @@index([ownerEmail])
}

enum TeamSessionStatus {
  OPEN
  CLOSED
  ARCHIVED
}

// ============================================================
// TEAM MEMBER
// Join table between Profile and TeamSession.
// Allows a profile to participate in multiple teams.
// ============================================================

model TeamMember {
  id          String   @id @default(cuid())
  sessionId   String
  profileId   String

  // Display name shown in this session's report
  // (might differ between sessions, e.g. "Mette" vs "Marketing-Mette")
  displayName String

  joinedAt    DateTime  @default(now())
  submittedAt DateTime?

  session     TeamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([sessionId, profileId])
  @@index([sessionId])
  @@index([profileId])
}

// ============================================================
// TEAM REQUEST
// Lead magnet form submission.
// Owner reviews and approves manually, creating a session.
// ============================================================

model TeamRequest {
  id        String   @id @default(cuid())

  // Form content
  name      String
  email     String
  company   String
  teamSize  String
  context   String?

  // Status
  status    TeamRequestStatus @default(NEW)

  // If approved, a session is created
  sessionId String?      @unique
  session   TeamSession? @relation(fields: [sessionId], references: [id])

  // Internal notes for owner
  notes     String?

  // Tracking
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([status])
  @@index([email])
}

enum TeamRequestStatus {
  NEW
  APPROVED
  DECLINED
  COMPLETED
}

// ============================================================
// PULSE — Statistical data from public APIs (DST etc.)
// ============================================================

model DataSource {
  id    String @id @default(cuid())

  slug            String  @unique  // e.g. "dst-aus08"
  name            String
  description     String?
  provider        String           // "dst"
  tableId         String           // DST table id, e.g. "AUS08"
  unit            String?          // "pct", "1000 persons", etc.
  sourceUrl       String?
  license         String?
  updateFrequency String?

  lastUpdatedAtSource DateTime?
  lastFetchedAt       DateTime?

  meta        Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dataPoints  DataPoint[]
  signals     Signal[]
  fetchLogs   FetchLog[]

  @@index([slug])
  @@index([provider, tableId])
}

model DataPoint {
  id         String @id @default(cuid())
  sourceId   String

  period     String    // "2026M03", "2026K1", "2026"
  periodDate DateTime  // first day of the period (UTC)
  periodType PeriodType

  areaCode   String?
  areaType   AreaType @default(NATIONAL)
  areaName   String?

  value      Float?
  status     String?  // "provisional", "missing", DST status codes

  dimensions Json?    // extra dimensions beyond time + area

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  source     DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, period, areaCode])
  @@index([sourceId, periodDate])
  @@index([sourceId, areaCode, periodDate])
}

enum PeriodType {
  MONTH
  QUARTER
  YEAR
  WEEK
}

enum AreaType {
  NATIONAL
  REGION
  LANDSDEL
  KOMMUNE
  OTHER
}

model Signal {
  id         String @id @default(cuid())
  sourceId   String

  type        String   // "TOP_MOVER", "RECORD", "STREAK", "COMPARISON", "TURNING_POINT", "OUTLIER"
  direction   String?  // "UP", "DOWN", "STABLE"
  severity    String   @default("info")  // "info", "note", "important"

  headline    String
  body        String?

  period      String?
  magnitude   Float?
  areaCode    String?
  areaName    String?
  evidence    Json?

  createdAt   DateTime @default(now())

  source      DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, type])
  @@index([sourceId, period])
}

model FetchLog {
  id         String @id @default(cuid())
  sourceId   String

  success      Boolean   @default(false)
  error        String?
  notes        String?

  inserted     Int @default(0)
  updated      Int @default(0)
  skipped      Int @default(0)
  rowsAffected Int @default(0)

  lastUpdatedAtSource DateTime?
  completedAt         DateTime?

  createdAt  DateTime @default(now())

  source     DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
}
